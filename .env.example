# Set whichever provider you want to use; the system auto-detects from
# whichever key is present. You can also force a provider with the
# LLM_PROVIDER env var or `--provider` CLI flag.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
CERIT_API_KEY=
CERIT_API_BASE=

# Force a specific provider when multiple keys are set. One of:
# openai | anthropic | gemini | cerit
#LLM_PROVIDER=

# server.py bind host and port (optional overrides)
#HOST=0.0.0.0
PORT=8003
# FRONTEND_PORT here only affects the server's startup banner.
# The frontend dev server reads its own FRONTEND_PORT from frontend/.env.
FRONTEND_PORT=5003